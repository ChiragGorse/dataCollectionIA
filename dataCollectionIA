startTime = time.time()
#start timer

url = "https://api.ftcscout.org/graphql"
#call api"

allTeams = []
teams = []
d = []
#set lists

n = 8000

query = f"""
query {{

teamsSearch(limit: {n}) {{
    number
}}
}}
"""
#query teams out of n team numbers

r = requests.post(url, json={"query": query})
res = r.json()

teamsData = res["data"]["teamsSearch"]
teams = [team["number"] for team in teamsData]

print(f"Got {len(teams)} teams")
#obtain teams

for team in teams:

    query = f"""
    query {{
    
    teamByNumber(number: {team}) {{
        quickStats(season: 2025) {{
          tot {{
            value
          }}
        }}
        sponsors
      }}
    }}
    """
    #query team number, average OPR, and sponsors (later converted into sponsor count)

    r = requests.post(url, json={"query": query})
    res = r.json()
    
    sponsors = len(res["data"]["teamByNumber"]["sponsors"])
    #obtain sponsor count

    potential = res["data"]["teamByNumber"]

    if potential["quickStats"] is not None:
        opr = potential["quickStats"]["tot"]["value"]
    else:
        opr = None

    if opr is not None:
        validTeamData = {
            "teamNumber": team,
            "opr": opr,
            "sponsors": sponsors
        }
        d.append(validTeamData)
        print(f"Got data for {team}")
    else:
        print(f"Team {team} doesn't exist")
    #skip over invalid team numbers given number
    #if the team is valid, then obtain proper output

oldLength = len(d)
sampleSize = 50 + 1 - 1

if len(d) >= sampleSize:
    d = random.sample(d, sampleSize)
    print(f"Randomly selected {sampleSize} teams from {oldLength} valid teams")
else:
    print(f"hello")
